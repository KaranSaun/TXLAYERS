# Database Configuration
DATABASE_URL=postgresql+asyncpg://texlayer:texlayer_pass@postgres:5432/texlayer_db

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_OUTPUTS=outputs

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# AI Processing Configuration
DELTA_E_MERGE_THRESHOLD=0.4
MAX_LAYERS=50
MAX_COLORWAYS=10
MODEL_PATH=/app/models_cache
CELERY_CONCURRENCY=2

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost/api
